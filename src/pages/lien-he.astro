---
import BaseLayout from "../layouts/BaseLayout.astro";
import ChatWidget from "../components/chat/ChatWidget.astro";
import { getStoreLocations, type SanityStore } from "../lib/groq/stores";
import { getSiteSettings } from "../lib/groq/siteSettings";

// Same fallback values as Footer.astro — kept until real content exists in Sanity.
const fallbackStores: SanityStore[] = [
  { name: "maybedding Cầu Diễn", isMain: true, address: "Số 101 đường Cầu Diễn, Hà Nội" },
  { name: "Chi nhánh Xuân Thủy", isMain: false, address: "Số 81 đường Xuân Thuỷ, Cầu Giấy, Hà Nội" },
];
const fallbackHotline = "0912.426.126";
const fallbackEmail = "maybedding.official@gmail.com";

const sanityStores = await getStoreLocations();
const stores = sanityStores.length > 0 ? sanityStores : fallbackStores;

const settings = await getSiteSettings();
const hotline = settings?.hotline ?? fallbackHotline;
const email = settings?.email ?? fallbackEmail;
---

<BaseLayout
  title="Liên Hệ - maybedding"
  description="Thông tin liên hệ, địa chỉ cửa hàng và giờ mở cửa của maybedding."
>
  <section class="py-section-gap max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="mb-12">
      <span class="text-primary font-bold tracking-widest uppercase text-xs mb-2 block">Liên hệ</span>
      <h1 class="text-headline-md text-on-surface">Ghé Thăm Hoặc Liên Hệ Với Chúng Tôi</h1>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter mb-16">
      {
        stores.map((store) => (
          <div class="bg-white rounded-xl border border-outline-variant/10 shadow-sm p-8">
            <h3 class="text-xl text-on-surface mb-4 flex items-center gap-2">
              <span class="material-symbols-outlined text-primary">storefront</span>
              {store.name}
              {store.isMain && (
                <span class="text-label-sm text-primary font-bold uppercase tracking-wide">(Chính)</span>
              )}
            </h3>
            <ul class="space-y-3 text-on-surface-variant/80 text-sm">
              <li class="flex gap-3">
                <span class="material-symbols-outlined text-primary text-sm">location_on</span>
                {store.address}
              </li>
              {store.openingHours && (
                <li class="flex gap-3">
                  <span class="material-symbols-outlined text-primary text-sm">schedule</span>
                  {store.openingHours}
                </li>
              )}
              {store.phone && (
                <li class="flex gap-3">
                  <span class="material-symbols-outlined text-primary text-sm">call</span>
                  <a href={`tel:${store.phone}`} class="hover:text-primary transition-colors">
                    {store.phone}
                  </a>
                </li>
              )}
            </ul>
            {store.googleMapsUrl && (
              <a
                href={store.googleMapsUrl}
                target="_blank"
                rel="noopener"
                class="mt-6 inline-flex items-center gap-2 text-secondary font-bold hover:underline"
              >
                Xem trên Google Maps
                <span class="material-symbols-outlined text-sm">open_in_new</span>
              </a>
            )}
          </div>
        ))
      }
    </div>

    <div class="bg-secondary rounded-3xl p-8 md:p-12 text-center text-white mb-16">
      <h2 class="text-headline-md mb-4">Cần Hỗ Trợ Nhanh?</h2>
      <p class="text-secondary-fixed mb-8">Gọi hotline hoặc gửi email cho chúng tôi, đội ngũ maybedding luôn sẵn sàng tư vấn.</p>
      <div class="flex flex-col md:flex-row justify-center gap-4">
        <a
          href={`tel:${hotline}`}
          class="bg-white text-secondary px-8 py-4 rounded-lg font-bold hover:bg-white/90 transition-all inline-flex items-center justify-center gap-2"
        >
          <span class="material-symbols-outlined">call</span>
          {hotline}
        </a>
        <a
          href={`mailto:${email}`}
          class="bg-transparent border border-white text-white px-8 py-4 rounded-lg font-bold hover:bg-white/10 transition-all inline-flex items-center justify-center gap-2"
        >
          <span class="material-symbols-outlined">mail</span>
          {email}
        </a>
      </div>
    </div>
  </section>
  <ChatWidget />
</BaseLayout>
