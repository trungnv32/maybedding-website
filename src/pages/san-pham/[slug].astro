---
import { marked } from "marked";
import { PortableText } from "astro-portabletext";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PortableImage from "../../components/blog/PortableImage.astro";
import ChatWidget from "../../components/chat/ChatWidget.astro";
import ActivityLightbox from "../../components/gallery/ActivityLightbox.astro";
import { getProductBySlug } from "../../lib/groq/products";

const { slug } = Astro.params;
const product = await getProductBySlug(slug!);

if (!product) {
  return Astro.rewrite("/404");
}

const hasBodyMarkdown = product.bodyMarkdown?.trim();
const bodyMarkdownHtml = hasBodyMarkdown ? marked.parse(product.bodyMarkdown!, { async: false }) : null;
const hasBody = product.body.length > 0;
const hasVariants = product.variants.length > 0;
const initialPrice = hasVariants ? product.variants[0].price : product.price;
const initialPrefill = hasVariants
  ? `Cho tôi hỏi thêm về sản phẩm "${product.name}" (${product.variants[0].label})`
  : `Cho tôi hỏi thêm về sản phẩm "${product.name}"`;
---

<BaseLayout title={`${product.name} - maybedding`} description={product.description}>
  <article class="py-section-gap max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <a href="/san-pham" class="text-secondary font-bold flex items-center gap-1 hover:underline w-fit mb-8">
      <span class="material-symbols-outlined text-sm">arrow_back</span> Quay lại danh sách sản phẩm
    </a>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
      <div>
        <button type="button" id="product-main-btn" data-gallery-thumb data-index="0" class="block w-full aspect-square overflow-hidden rounded-2xl bg-surface-container-low">
          <img id="product-main-image" src={product.image} alt={product.name} class="w-full h-full object-contain" />
        </button>
        {
          product.images.length > 1 && (
            <div class="flex gap-3 mt-4 overflow-x-auto pb-1">
              {product.images.map((url, i) => (
                <button
                  type="button"
                  data-thumb-index={i}
                  data-thumb-url={url}
                  class:list={[
                    "shrink-0 w-16 h-16 rounded-lg overflow-hidden border-2 transition-colors",
                    i === 0 ? "border-primary" : "border-transparent hover:border-outline-variant/40",
                  ]}
                >
                  <img src={url} alt={`${product.name} - ảnh ${i + 1}`} class="w-full h-full object-cover" />
                </button>
              ))}
            </div>
          )
        }
      </div>
      <div>
        {product.category && <span class="text-secondary text-label-sm">{product.category}</span>}
        {product.badge && <span class="block text-primary font-bold uppercase text-xs tracking-widest mt-1">{product.badge}</span>}
        <h1 class="text-headline-md text-on-surface mt-2">{product.name}</h1>
        <p id="product-price-display" class="text-secondary font-bold text-2xl mt-3">{initialPrice}</p>

        {
          hasVariants && (
            <div class="mt-4">
              <label for="product-variant-select" class="text-sm font-medium text-on-surface-variant block mb-2">
                Chọn kích thước / phân loại:
              </label>
              <select
                id="product-variant-select"
                class="w-full md:w-auto px-4 py-3 rounded-lg border border-outline-variant/30 text-on-surface bg-white"
              >
                {product.variants.map((v) => (
                  <option value={v.price} data-label={v.label}>
                    {v.label} — {v.price}
                  </option>
                ))}
              </select>
            </div>
          )
        }

        <div class="prose-blog text-body-md text-on-surface-variant leading-relaxed mt-6">
          {
            bodyMarkdownHtml ? (
              <Fragment set:html={bodyMarkdownHtml} />
            ) : hasBody ? (
              <PortableText value={product.body} components={{ type: { image: PortableImage } }} />
            ) : (
              <p>{product.description}</p>
            )
          }
        </div>
        <button
          type="button"
          id="product-chat-btn"
          class="chat-open-btn w-full md:w-auto mt-8 bg-primary text-white px-10 py-4 rounded-lg font-bold hover:bg-red-800 transition-colors"
          data-prefill={initialPrefill}
        >
          Hỏi ngay về sản phẩm này
        </button>
      </div>
    </div>
  </article>
  <ChatWidget />
</BaseLayout>

<ActivityLightbox images={product.images.map((url) => ({ url, alt: product.name }))} />

<script define:vars={{ productName: product.name, hasVariants }}>
  const mainImg = document.getElementById("product-main-image");
  const mainBtn = document.getElementById("product-main-btn");
  document.querySelectorAll("[data-thumb-index]").forEach((thumb) => {
    thumb.addEventListener("click", () => {
      const url = thumb.dataset.thumbUrl;
      const index = thumb.dataset.thumbIndex;
      if (mainImg && url) mainImg.src = url;
      if (mainBtn && index) mainBtn.dataset.index = index;
      document.querySelectorAll("[data-thumb-index]").forEach((t) => t.classList.remove("border-primary"));
      document.querySelectorAll("[data-thumb-index]").forEach((t) => t.classList.add("border-transparent"));
      thumb.classList.remove("border-transparent");
      thumb.classList.add("border-primary");
    });
  });

  if (hasVariants) {
    const select = document.getElementById("product-variant-select");
    const priceDisplay = document.getElementById("product-price-display");
    const chatBtn = document.getElementById("product-chat-btn");
    select?.addEventListener("change", () => {
      const option = select.options[select.selectedIndex];
      if (priceDisplay) priceDisplay.textContent = option.value;
      if (chatBtn) chatBtn.dataset.prefill = `Cho tôi hỏi thêm về sản phẩm "${productName}" (${option.dataset.label})`;
    });
  }
</script>

<style>
  .prose-blog :global(h2) {
    font-size: 24px;
    font-weight: 600;
    color: var(--color-on-surface);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-blog :global(p) {
    margin-bottom: 1rem;
  }
  .prose-blog :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
</style>
