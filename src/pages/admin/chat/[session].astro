---
import "../../../styles/global.css";
import { isAuthed } from "../../../lib/adminAuth";
import { getMessages, sendAdminMessage } from "../../../lib/adminChatApi";

const cookie = Astro.cookies.get("admin_auth")?.value;
if (!isAuthed(cookie)) {
  return Astro.redirect("/admin/login");
}

const { session } = Astro.params;
// Astro does not auto-decode dynamic route params — the URL segment arrives as
// "web%3Auuid" (still percent-encoded), so decode once before using it anywhere.
const sessionId = decodeURIComponent(session!);

let sendError: string | null = null;
if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const message = formData.get("message")?.toString().trim();
  const mode = formData.get("mode")?.toString() === "nudge" ? "nudge" : "reply";
  if (message) {
    try {
      await sendAdminMessage(sessionId, mode, message);
      return Astro.redirect(`/admin/chat/${encodeURIComponent(sessionId)}`);
    } catch (err) {
      sendError = err instanceof Error ? err.message : "Lỗi không xác định";
    }
  }
}

let aiHistory: Awaited<ReturnType<typeof getMessages>>["aiHistory"] = [];
let extraMessages: Awaited<ReturnType<typeof getMessages>>["extraMessages"] = [];
let loadError: string | null = null;
try {
  ({ aiHistory, extraMessages } = await getMessages(sessionId));
} catch (err) {
  loadError = err instanceof Error ? err.message : "Lỗi không xác định";
}

const ROLE_LABEL: Record<string, string> = { human: "Khách", ai: "AI (Gia Hân)", tool: "AI (tra cứu dữ liệu)" };

// Tool-call steps get logged as role "ai" too (e.g. "Calling call_human_zalo with input: {...}"),
// not just role "tool" — filter those out by their distinctive prefix, not just by role.
const visibleAiHistory = aiHistory
  .filter((m) => (m.role === "human" || m.role === "ai") && !/^Calling .+ with input:/.test(m.content))
  .reverse();
const visibleExtraMessages = [...extraMessages].reverse();
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content="15" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{sessionId} - maybedding</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="bg-surface text-on-surface min-h-screen">
    <div class="max-w-2xl mx-auto px-6 py-10">
      <a href="/admin/chat" class="text-secondary font-bold text-sm hover:underline">&larr; Danh sách phiên</a>
      <h1 class="text-headline-md text-on-surface mt-2 mb-6 break-all">{sessionId}</h1>

      {(loadError || sendError) && (
        <p class="text-red-600 bg-red-50 border border-red-200 rounded-lg p-4 text-sm mb-6">{loadError ?? sendError}</p>
      )}

      <section class="mb-8">
        <h2 class="font-bold text-on-surface mb-3">Hội thoại với AI</h2>
        <div class="space-y-2 max-h-96 overflow-y-auto bg-white border border-outline-variant/10 rounded-xl p-4">
          {
            visibleAiHistory.map((m) => (
              <div class="text-sm">
                <span class="font-bold text-secondary">{ROLE_LABEL[m.role] ?? m.role}:</span>{" "}
                <span class="text-on-surface-variant whitespace-pre-wrap break-words">{m.content}</span>
              </div>
            ))
          }
          {visibleAiHistory.length === 0 && <p class="text-on-surface-variant/70 text-sm">Chưa có tin nhắn.</p>}
        </div>
      </section>

      <section class="mb-8">
        <h2 class="font-bold text-on-surface mb-3">Tin nhắn ngoài AI (khi bot tạm dừng)</h2>
        <div class="space-y-2 bg-white border border-outline-variant/10 rounded-xl p-4">
          {
            visibleExtraMessages.map((m) => (
              <div class="text-sm">
                <span class="font-bold text-secondary">{m.sender === "admin" ? "Bạn (admin)" : "Khách"}:</span>{" "}
                <span class="text-on-surface-variant whitespace-pre-wrap break-words">{m.content}</span>
              </div>
            ))
          }
          {visibleExtraMessages.length === 0 && <p class="text-on-surface-variant/70 text-sm">Chưa có.</p>}
        </div>
      </section>

      <form method="POST" class="bg-secondary rounded-xl p-6">
        <label class="flex items-center gap-2 text-white text-sm mb-2">
          <input type="radio" name="mode" value="reply" checked /> Gửi thẳng cho khách (bot tạm dừng ~10 phút)
        </label>
        <label class="flex items-center gap-2 text-white text-sm mb-4">
          <input type="radio" name="mode" value="nudge" /> Nhắc AI (bot vẫn tự trả lời, làm theo chỉ dẫn này ở câu tiếp theo)
        </label>
        <textarea
          name="message"
          required
          rows="3"
          placeholder="Nhập nội dung..."
          class="w-full px-4 py-3 rounded-lg border-none mb-4 outline-none bg-white text-black placeholder:text-gray-400"
        ></textarea>
        <button type="submit" class="bg-white text-secondary px-8 py-3 rounded-lg font-bold hover:bg-white/90 transition-colors">
          Gửi
        </button>
      </form>
    </div>
  </body>
</html>
