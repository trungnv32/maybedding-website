---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Không tìm thấy trang - maybedding" description="Trang bạn tìm không tồn tại.">
  <section class="py-section-gap max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop text-center">
    <h1 class="text-headline-md text-on-surface mb-4">404 - Không tìm thấy trang</h1>
    <p class="text-on-surface-variant/80 mb-8">Trang bạn đang tìm không tồn tại hoặc đã được di chuyển.</p>
    <a href="/" class="inline-block bg-primary text-white px-8 py-4 rounded-lg font-bold hover:bg-red-800 transition-all">
      Về trang chủ
    </a>
  </section>
</BaseLayout>
