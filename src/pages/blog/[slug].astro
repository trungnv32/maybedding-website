---
import { marked } from "marked";
import { PortableText } from "astro-portabletext";
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import PortableImage from "../../components/blog/PortableImage.astro";
import { getBlogPostBySlug } from "../../lib/groq/blog";

const { slug } = Astro.params;
const post = await getBlogPostBySlug(slug!);

if (!post) {
  return Astro.rewrite("/404");
}

const description = post.metaDescription ?? post.excerpt;

// Bài do công cụ tự động sinh lưu Markdown thô trong bodyMarkdown — ưu tiên hiển
// thị trường này nếu có nội dung, thay vì body (Portable Text) chỉ dùng cho bài
// viết tay qua Sanity Studio.
const bodyMarkdownHtml = post.bodyMarkdown?.trim()
  ? marked.parse(post.bodyMarkdown, { async: false })
  : null;
---

<BlogPostLayout
  title={post.metaTitle ?? post.title}
  description={description}
  coverImage={post.coverImage}
  coverImageAlt={post.coverImageAlt}
  category={post.category}
  publishedAt={new Date(post.publishedAt)}
  author={post.author}
>
  {
    bodyMarkdownHtml ? (
      <Fragment set:html={bodyMarkdownHtml} />
    ) : (
      <PortableText value={post.body} components={{ type: { image: PortableImage } }} />
    )
  }
</BlogPostLayout>
