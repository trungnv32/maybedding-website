---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogCard from "../../components/blog/BlogCard.astro";
import { getBlogPosts } from "../../lib/groq/blog";

const PAGE_SIZE = 9;

// No getStaticPaths in server mode: pagination is computed per-request from the
// [...page] rest param so new posts show up immediately without a rebuild.
const pageParam = Astro.params.page;
const pageNum = pageParam ? Number(pageParam) : 1;
if (pageParam && (!Number.isInteger(pageNum) || pageNum < 2 || String(pageNum) !== pageParam)) {
  return Astro.rewrite("/404");
}

const allPosts = await getBlogPosts();
const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));
if (pageNum > totalPages) {
  return Astro.rewrite("/404");
}

const posts = allPosts.slice((pageNum - 1) * PAGE_SIZE, pageNum * PAGE_SIZE);
const prevUrl = pageNum > 1 ? (pageNum === 2 ? "/blog" : `/blog/${pageNum - 1}`) : null;
const nextUrl = pageNum < totalPages ? `/blog/${pageNum + 1}` : null;
---

<BaseLayout
  title="Blog - maybedding"
  description="Kiến thức và kinh nghiệm chăm sóc chăn ga gối đệm, giấc ngủ và sức khỏe cột sống từ đội ngũ maybedding."
>
  <section class="py-section-gap max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="mb-12">
      <span class="text-primary font-bold tracking-widest uppercase text-xs mb-2 block">Blog</span>
      <h1 class="text-headline-md text-on-surface">Kiến Thức & Kinh Nghiệm Giấc Ngủ</h1>
    </div>
    {
      posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
          {posts.map((post) => (
            <BlogCard
              slug={post.slug}
              title={post.title}
              excerpt={post.excerpt}
              coverImage={post.coverImage}
              coverImageAlt={post.coverImageAlt}
              category={post.category}
              publishedAt={new Date(post.publishedAt)}
            />
          ))}
        </div>
      ) : (
        <p class="text-on-surface-variant/70">Bài viết đang được cập nhật, mời bạn quay lại sau.</p>
      )
    }
    {
      (prevUrl || nextUrl) && (
        <div class="flex justify-center gap-4 mt-16">
          {prevUrl && (
            <a href={prevUrl} class="px-6 py-3 rounded-lg border border-secondary text-secondary font-bold hover:bg-secondary/5 transition-all">
              Trang trước
            </a>
          )}
          {nextUrl && (
            <a href={nextUrl} class="px-6 py-3 rounded-lg border border-secondary text-secondary font-bold hover:bg-secondary/5 transition-all">
              Trang sau
            </a>
          )}
        </div>
      )
    }
  </section>
</BaseLayout>
