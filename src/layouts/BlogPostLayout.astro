---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  coverImage: string;
  coverImageAlt: string;
  category: string;
  publishedAt: Date;
  author: string;
}

const { title, description, coverImage, coverImageAlt, category, publishedAt, author } = Astro.props;

const formattedDate = publishedAt.toLocaleDateString("vi-VN", {
  day: "2-digit",
  month: "2-digit",
  year: "numeric",
});

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  image: new URL(coverImage, Astro.site).toString(),
  datePublished: publishedAt.toISOString(),
  author: { "@type": "Organization", name: author },
  publisher: { "@type": "Organization", name: "maybedding" },
};
---

<BaseLayout title={`${title} - Blog maybedding`} description={description} ogImage={coverImage} ogType="article">
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="max-w-3xl mx-auto px-margin-mobile md:px-margin-desktop py-section-gap">
    <div class="mb-8">
      <a href="/blog" class="text-secondary font-bold flex items-center gap-1 hover:underline w-fit mb-6">
        <span class="material-symbols-outlined text-sm">arrow_back</span> Quay lại Blog
      </a>
      <div class="flex items-center gap-3 text-label-sm text-secondary uppercase tracking-wide">
        <span>{category}</span>
        <span class="text-on-surface-variant/40">•</span>
        <span class="text-on-surface-variant/60 normal-case tracking-normal">{formattedDate}</span>
      </div>
      <h1 class="text-display-lg-mobile md:text-display-lg text-on-surface mt-3 leading-tight">{title}</h1>
      <p class="text-on-surface-variant/60 text-sm mt-3">Viết bởi {author}</p>
    </div>
    <img src={coverImage} alt={coverImageAlt} class="w-full aspect-video object-cover rounded-2xl shadow-xl mb-10" />
    <div class="prose-blog text-body-md text-on-surface-variant leading-relaxed">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .prose-blog :global(h2) {
    font-size: 24px;
    font-weight: 600;
    color: var(--color-on-surface);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose-blog :global(p) {
    margin-bottom: 1.25rem;
  }
  .prose-blog :global(hr) {
    border-color: var(--color-outline-variant);
    margin: 2rem 0;
  }
  .prose-blog :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .prose-blog :global(ol) {
    list-style: decimal;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .prose-blog :global(h3) {
    font-size: 20px;
    font-weight: 600;
    color: var(--color-on-surface);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .prose-blog :global(strong) {
    color: var(--color-on-surface);
    font-weight: 600;
  }
  .prose-blog :global(blockquote) {
    border-left: 3px solid var(--color-outline-variant);
    padding-left: 1rem;
    margin: 1.25rem 0;
    color: var(--color-on-surface-variant);
    font-style: italic;
  }
  .prose-blog :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 14px;
  }
  .prose-blog :global(th),
  .prose-blog :global(td) {
    border: 1px solid var(--color-outline-variant);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .prose-blog :global(th) {
    background: var(--color-surface-container);
    font-weight: 600;
    color: var(--color-on-surface);
  }
</style>
