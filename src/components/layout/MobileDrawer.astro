---
const navItems = [
  { href: "/", icon: "home", label: "Trang Chủ", active: true },
  { href: "/ve-chung-toi", icon: "info", label: "Giới thiệu", active: false },
  { href: "/san-pham", icon: "bed", label: "Sản phẩm & Dịch vụ", active: false },
  { href: "/blog", icon: "auto_stories", label: "Blog", active: false },
];
---

<div
  id="side-drawer"
  class="fixed inset-y-0 left-0 z-[60] flex flex-col h-full w-80 bg-surface shadow-xl -translate-x-full transition-transform duration-300"
>
  <div class="p-6 border-b border-outline-variant/10 flex justify-between items-center">
    <h2 class="text-headline-md text-primary">Menu</h2>
    <button class="material-symbols-outlined text-on-surface-variant" id="drawer-close">close</button>
  </div>
  <nav class="flex-1 py-4">
    {
      navItems.map((item) => (
        <a
          class={
            item.active
              ? "flex items-center gap-4 bg-secondary-container text-on-secondary-container rounded-full px-6 py-3 mx-4 mb-2 scale-95 transition-transform"
              : "flex items-center gap-4 text-on-surface-variant px-6 py-3 mx-4 mb-2 hover:bg-surface-container-high transition-all"
          }
          href={item.href}
        >
          <span class="material-symbols-outlined">{item.icon}</span>
          <span class="text-label-sm">{item.label}</span>
        </a>
      ))
    }
  </nav>
</div>
<div
  id="drawer-overlay"
  class="fixed inset-0 bg-black/20 z-[55] hidden opacity-0 transition-opacity duration-300"
></div>
