---
import { getNavigation, type SanityMenuItem } from "../../lib/groq/navigation";

const fallbackHeaderMenu: SanityMenuItem[] = [
  { href: "/", label: "Trang Chủ" },
  { href: "/san-pham", label: "Sản Phẩm" },
  { href: "/dich-vu", label: "Dịch Vụ" },
  { href: "/lien-he", label: "Liên Hệ" },
];

const nav = await getNavigation();
const navItems = nav?.headerMenu?.length ? nav.headerMenu : fallbackHeaderMenu;

const currentPath = Astro.url.pathname;
function isActive(href: string) {
  return href === "/" ? currentPath === "/" : currentPath.startsWith(href);
}
---

<header class="sticky top-0 w-full z-50 bg-surface-bright border-b border-outline-variant/10 shadow-sm">
  <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-4 flex justify-between items-center">
    <div class="flex items-center gap-4">
      <button class="material-symbols-outlined text-primary hover:opacity-80 transition-opacity" id="drawer-open">menu</button>
      <a href="/" class="text-headline-md font-bold text-primary tracking-tight">maybedding</a>
    </div>
    <nav class="hidden md:flex gap-8">
      {
        navItems.map((item) => (
          <a
            class={
              isActive(item.href)
                ? "text-primary border-b-2 border-primary font-medium"
                : "text-on-surface-variant/80 hover:text-secondary transition-colors duration-300"
            }
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="flex items-center gap-4">
      <span class="material-symbols-outlined text-primary cursor-pointer hover:scale-110 transition-transform">search</span>
    </div>
  </div>
</header>
