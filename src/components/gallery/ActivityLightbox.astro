---
interface Props {
  images: { url: string; alt: string; caption?: string }[];
}
const { images } = Astro.props;
---

{
  images.length > 0 && (
    <div
      id="activity-lightbox"
      class="fixed inset-0 z-[100] hidden bg-black/95"
      data-images={JSON.stringify(images)}
    >
      <div class="absolute top-0 inset-x-0 z-10 flex items-start justify-between gap-4 p-4 md:p-6">
        <p
          id="activity-lightbox-caption"
          class="hidden text-white text-sm md:text-base bg-black/60 rounded-lg px-4 py-2 max-w-[70%] leading-snug"
        />
        <button
          id="activity-lightbox-close"
          aria-label="Đóng"
          class="w-11 h-11 shrink-0 rounded-full bg-black/60 text-white flex items-center justify-center hover:bg-black/80 transition-colors"
        >
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>

      <button
        id="activity-lightbox-prev"
        aria-label="Ảnh trước"
        class="hidden md:flex absolute left-4 top-1/2 -translate-y-1/2 z-10 w-12 h-12 rounded-full bg-black/60 text-white items-center justify-center hover:bg-black/80 transition-colors"
      >
        <span class="material-symbols-outlined">chevron_left</span>
      </button>
      <button
        id="activity-lightbox-next"
        aria-label="Ảnh sau"
        class="hidden md:flex absolute right-4 top-1/2 -translate-y-1/2 z-10 w-12 h-12 rounded-full bg-black/60 text-white items-center justify-center hover:bg-black/80 transition-colors"
      >
        <span class="material-symbols-outlined">chevron_right</span>
      </button>

      <div id="activity-lightbox-stage" class="absolute inset-0 flex items-center justify-center overflow-hidden touch-none">
        <img id="activity-lightbox-img" src="" alt="" class="max-w-none select-none will-change-transform" draggable="false" />
      </div>

      <div class="absolute bottom-6 inset-x-0 z-10 flex items-center justify-center gap-3">
        <button
          id="activity-lightbox-zoom-out"
          aria-label="Thu nhỏ"
          class="w-11 h-11 rounded-full bg-black/60 text-white flex items-center justify-center hover:bg-black/80 transition-colors"
        >
          <span class="material-symbols-outlined">zoom_out</span>
        </button>
        <button
          id="activity-lightbox-zoom-in"
          aria-label="Phóng to"
          class="w-11 h-11 rounded-full bg-black/60 text-white flex items-center justify-center hover:bg-black/80 transition-colors"
        >
          <span class="material-symbols-outlined">zoom_in</span>
        </button>
      </div>
    </div>
  )
}

<script>
  const lightbox = document.getElementById("activity-lightbox") as HTMLDivElement | null;
  if (lightbox) {
    const images: { url: string; alt: string; caption?: string }[] = JSON.parse(lightbox.dataset.images || "[]");
    const imgEl = document.getElementById("activity-lightbox-img") as HTMLImageElement;
    const captionEl = document.getElementById("activity-lightbox-caption") as HTMLParagraphElement;
    const stage = document.getElementById("activity-lightbox-stage") as HTMLDivElement;
    const closeBtn = document.getElementById("activity-lightbox-close") as HTMLButtonElement;
    const prevBtn = document.getElementById("activity-lightbox-prev") as HTMLButtonElement;
    const nextBtn = document.getElementById("activity-lightbox-next") as HTMLButtonElement;
    const zoomInBtn = document.getElementById("activity-lightbox-zoom-in") as HTMLButtonElement;
    const zoomOutBtn = document.getElementById("activity-lightbox-zoom-out") as HTMLButtonElement;

    const MIN_SCALE = 1;
    const MAX_SCALE = 3;
    const SWIPE_THRESHOLD = 60;

    let index = 0;
    let scale = MIN_SCALE;
    let originX = 0;
    let originY = 0;

    function applyTransform() {
      imgEl.style.transform = `translate(${originX}px, ${originY}px) scale(${scale})`;
    }

    function render() {
      const item = images[index];
      imgEl.src = item.url;
      imgEl.alt = item.alt;
      captionEl.textContent = item.caption ?? "";
      captionEl.classList.toggle("hidden", !item.caption);
      scale = MIN_SCALE;
      originX = 0;
      originY = 0;
      applyTransform();
    }

    function open(i: number) {
      index = i;
      render();
      lightbox!.classList.remove("hidden");
      document.body.classList.add("overflow-hidden");
    }

    function close() {
      lightbox!.classList.add("hidden");
      document.body.classList.remove("overflow-hidden");
    }

    function go(delta: number) {
      index = (index + delta + images.length) % images.length;
      render();
    }

    closeBtn.addEventListener("click", close);
    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) close();
    });
    prevBtn.addEventListener("click", () => go(-1));
    nextBtn.addEventListener("click", () => go(1));

    zoomInBtn.addEventListener("click", () => {
      scale = Math.min(MAX_SCALE, scale + 0.5);
      applyTransform();
    });
    zoomOutBtn.addEventListener("click", () => {
      scale = Math.max(MIN_SCALE, scale - 0.5);
      if (scale === MIN_SCALE) {
        originX = 0;
        originY = 0;
      }
      applyTransform();
    });
    imgEl.addEventListener("dblclick", () => {
      scale = scale > MIN_SCALE ? MIN_SCALE : 2;
      originX = 0;
      originY = 0;
      applyTransform();
    });

    document.addEventListener("keydown", (e) => {
      if (lightbox!.classList.contains("hidden")) return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowLeft") go(-1);
      if (e.key === "ArrowRight") go(1);
    });

    // Drag pans the image while zoomed in; at 1x the same gesture swipes to the
    // next/previous photo instead — one gesture, two meanings depending on scale.
    let dragging = false;
    let startX = 0;
    let startY = 0;
    let startOriginX = 0;
    let startOriginY = 0;

    stage.addEventListener("pointerdown", (e) => {
      dragging = true;
      startX = e.clientX;
      startY = e.clientY;
      startOriginX = originX;
      startOriginY = originY;
      stage.setPointerCapture(e.pointerId);
    });
    stage.addEventListener("pointermove", (e) => {
      if (!dragging || scale === MIN_SCALE) return;
      originX = startOriginX + (e.clientX - startX);
      originY = startOriginY + (e.clientY - startY);
      applyTransform();
    });
    stage.addEventListener("pointerup", (e) => {
      if (!dragging) return;
      dragging = false;
      const dx = e.clientX - startX;
      if (scale === MIN_SCALE && Math.abs(dx) > SWIPE_THRESHOLD) {
        go(dx < 0 ? 1 : -1);
      }
    });
    stage.addEventListener("pointercancel", () => {
      dragging = false;
    });

    document.querySelectorAll<HTMLButtonElement>("[data-gallery-thumb]").forEach((btn) => {
      btn.addEventListener("click", () => {
        open(Number(btn.dataset.index ?? "0"));
      });
    });
  }
</script>
