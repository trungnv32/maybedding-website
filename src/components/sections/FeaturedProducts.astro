      Xem tất cả <span class="material-symbols-outlined text-sm">arrow_forward</span>
    </a>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
    {products.map((product) => <ProductCard {...product} />)}
