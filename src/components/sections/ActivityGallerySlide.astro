---
import ActivityLightbox from "../gallery/ActivityLightbox.astro";
import { getActivityGalleryImages } from "../../lib/groq/activityGallery";

const allImages = await getActivityGalleryImages();
const previewImages = allImages.slice(0, 3);
---

{
  previewImages.length > 0 && (
    <section class="py-section-gap max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
      <div class="flex justify-between items-end mb-12">
        <div>
          <span class="text-primary font-bold tracking-widest uppercase text-xs mb-2 block">Hoạt động</span>
          <h3 class="text-headline-md text-on-surface">Khoảnh Khắc Tại maybedding</h3>
        </div>
        <a class="text-secondary font-bold flex items-center gap-1 hover:underline" href="/hoat-dong">
          Xem toàn bộ hoạt động <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-gutter">
        {previewImages.map((image, i) => (
          <button type="button" data-gallery-thumb data-index={i} class="block group">
            <img
              src={image.url}
              alt={image.alt}
              class="w-full aspect-[4/3] object-cover rounded-2xl shadow-md group-hover:opacity-90 transition-opacity"
            />
          </button>
        ))}
      </div>
    </section>
  )
}

<ActivityLightbox images={previewImages} />
