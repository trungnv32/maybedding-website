---
// Phase 1: ported as-is from the current static site.
// Phase 4 (per plan): this section is replaced by ChatWidget.astro (AI chat backed by n8n).
---

<section class="mb-section-gap max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
  <div class="bg-secondary rounded-3xl p-12 md:p-20 text-center relative overflow-hidden">
    <div class="absolute top-0 left-0 w-64 h-64 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-primary/10 rounded-full translate-x-1/3 translate-y-1/3"></div>
    <div class="relative z-10">
      <h3 class="text-white text-headline-md text-3xl mb-4">Nhận ưu đãi 10% cho đơn hàng đầu tiên</h3>
      <p class="text-secondary-fixed mb-10 max-w-xl mx-auto">
        Đăng ký bản tin để cập nhật những xu hướng trang trí phòng ngủ mới nhất và nhận voucher giảm giá độc quyền hàng
        tháng.
      </p>
      <form class="flex flex-col md:flex-row gap-4 max-w-md mx-auto">
        <input
          class="flex-1 px-6 py-4 rounded-lg bg-white border-none focus:ring-2 focus:ring-primary-fixed outline-none text-on-surface"
          placeholder="Email của bạn..."
          type="email"
        />
        <button class="bg-primary text-white px-8 py-4 rounded-lg font-bold hover:bg-red-800 transition-all" type="submit">
          Đăng ký ngay
        </button>
      </form>
    </div>
  </div>
</section>
